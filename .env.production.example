# ─── Ycontrol Cloud – Produktions-Umgebungsvariablen ─────────────────────────
# Kopiere diese Datei nach .env und trage alle Werte ein.
# NIEMALS .env in Git committen!

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token aus dem Cloudflare Zero Trust Dashboard (Tunnels → Tunnel erstellen → Token kopieren)
CLOUDFLARE_TUNNEL_TOKEN=AENDERN_token_aus_cloudflare_dashboard

# ─── App URL (für CORS im Backend) ───────────────────────────────────────────
# Vollständige URL deiner App (so wie sie in Cloudflare konfiguriert ist)
APP_URL=https://cloud.deine-domain.de

# ─── Datenbank ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=AENDERN_sicheres_passwort_hier
DB_NAME=ycontrol_cloud

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Mindestens 64 zufällige Zeichen – generieren mit: openssl rand -hex 64
JWT_ACCESS_SECRET=AENDERN_access_secret_mindestens_64_zeichen
JWT_REFRESH_SECRET=AENDERN_refresh_secret_mindestens_64_zeichen
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── At-Rest-Verschlüsselung sensibler Settings ──────────────────────────────
# Master-Key für die AES-256-GCM-Verschlüsselung von S3-Keys, SMTP-Passwort,
# Twilio-Token, DeepL-API-Key in der DB. 32 Byte = 64 Hex-Zeichen.
# Generieren mit: openssl rand -hex 32
# WICHTIG: Nach Änderung können bestehende Secrets nicht mehr entschlüsselt
# werden → vor Rotation erst alle Secrets manuell neu eingeben.
SECRETS_KEY=AENDERN_secrets_key_64_hex_zeichen

# ─── WireGuard VPN ───────────────────────────────────────────────────────────
# Privater Server-Schlüssel (generieren: wg genkey)
# Der zugehörige öffentliche Schlüssel wird im Cloud-UI unter VPN → Einstellungen eingetragen.
VPN_SERVER_PRIVATE_KEY=AENDERN_wireguard_server_private_key

# ─── MQTT (Mosquitto + go-auth) ───────────────────────────────────────────────
# MQTT_AUTH_SECRET: internes Geheimnis für Geräteanmeldung (beliebig, mind. 32 Zeichen)
MQTT_AUTH_SECRET=AENDERN_mqtt_auth_secret
# MQTT_BACKEND_USER / MQTT_BACKEND_PASSWORD: Zugangsdaten für den Backend-Client
MQTT_BACKEND_USER=backend-client
MQTT_BACKEND_PASSWORD=AENDERN_mqtt_backend_passwort
