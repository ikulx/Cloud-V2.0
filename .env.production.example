# ─── Ycontrol Cloud – Produktions-Umgebungsvariablen ─────────────────────────
# Kopiere diese Datei nach .env und trage alle Werte ein.
# NIEMALS .env in Git committen!

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token aus dem Cloudflare Zero Trust Dashboard (Tunnels → Tunnel erstellen → Token kopieren)
CLOUDFLARE_TUNNEL_TOKEN=AENDERN_token_aus_cloudflare_dashboard

# ─── App URL (für CORS im Backend) ───────────────────────────────────────────
# Vollständige URL deiner App (so wie sie in Cloudflare konfiguriert ist)
APP_URL=https://cloud.deine-domain.de

# ─── Datenbank ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=AENDERN_sicheres_passwort_hier
DB_NAME=ycontrol_cloud

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Mindestens 64 zufällige Zeichen – generieren mit: openssl rand -hex 64
JWT_ACCESS_SECRET=AENDERN_access_secret_mindestens_64_zeichen
JWT_REFRESH_SECRET=AENDERN_refresh_secret_mindestens_64_zeichen
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MQTT / EMQX ─────────────────────────────────────────────────────────────
MQTT_AUTH_SECRET=AENDERN_mqtt_auth_secret
MQTT_BACKEND_USER=backend-client
MQTT_BACKEND_PASSWORD=AENDERN_mqtt_backend_passwort
EMQX_DASHBOARD_PASSWORD=AENDERN_emqx_dashboard_passwort
