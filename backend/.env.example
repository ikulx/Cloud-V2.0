DATABASE_URL="postgresql://postgres:password@localhost:5432/ycontrol_cloud"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
MQTT_AUTH_SECRET="change-me-mqtt-internal-secret"
MQTT_BACKEND_USER="backend-client"
MQTT_BACKEND_PASSWORD="change-me-backend-mqtt-password"
MQTT_URL="mqtt://localhost:1883"

# DeepL – automatische Wiki-Übersetzung
# Kostenloser API-Key: https://www.deepl.com/de/pro-api (500k Zeichen/Monat)
# Leer lassen → Wiki wird nicht automatisch übersetzt (Feature deaktiviert)
DEEPL_API_KEY=""
# 'free' (Standard) oder 'pro'
DEEPL_TIER="free"
