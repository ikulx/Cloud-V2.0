generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DeviceStatus {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum TodoStatus {
  OPEN
  DONE
}

enum WikiNodeType {
  FOLDER
  PAGE
}

enum WikiAccessLevel {
  VIEW
  EDIT
}

enum WikiAccessTarget {
  ROLE
  GROUP
  USER
}

enum AnlageContract {
  NONE
  A
  B
  C
}

// ─── Alarme (Cloud-seitiger Alarmmanager) ─────────────────────────────────────
// Der Pi (Visu/Agent) erkennt Alarme lokal (Bit/Comparison-Regeln) und sendet
// fertige Alarm-Events via MQTT an die Cloud. Die Cloud verwaltet die
// Empfänger (pro Anlage) und übernimmt den Versand (aktuell Email, später
// SMS/Telegram).

enum AlarmPriority {
  PRIO1
  PRIO2
  PRIO3
  WARNING
  INFO
}

enum AlarmRecipientType {
  EMAIL
  SMS
  /// Beides: target = E-Mail-Adresse, smsTarget = Telefonnummer.
  /// Dispatcher erzeugt zwei Deliveries (eine pro Kanal).
  EMAIL_AND_SMS
  TELEGRAM
}

/// Zustand eines Alarm-Events.
/// ACTIVE: Pi meldet den Alarm als aktiv. CLEARED: Pi hat Alarm zurückgenommen
/// (Bit wieder 0 / Comparison nicht mehr erfüllt). ACKNOWLEDGED: Ein User hat
/// den Alarm in der Cloud manuell quittiert.
enum AlarmEventStatus {
  ACTIVE
  CLEARED
  ACKNOWLEDGED
}

enum AlarmDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  address      String?
  /// Mobilnummer (E.164, z.B. +41791234567). Pflicht für Piket-Techniker.
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  /// Zählt aufeinanderfolgende fehlgeschlagene Login-Versuche. Wird bei
  /// erfolgreichem Login auf 0 zurückgesetzt.
  failedLoginCount Int    @default(0) @map("failed_login_count")
  /// Wenn gesetzt und in der Zukunft: Account ist bis dahin gesperrt.
  lockedUntil      DateTime? @map("locked_until")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roleId String? @map("role_id") @db.Uuid
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  groupMemberships UserGroupMember[]
  directAnlagen    UserDirectAnlage[]
  directDevices    UserDirectDevice[]
  refreshTokens    RefreshToken[]
  authChallenges   AuthChallenge[]
  passwordResets   PasswordResetToken[]
  vpnPeers         VpnPeer[]

  createdAnlageTodos  AnlageTodo[]     @relation("AnlageTodoAuthor")
  assignedAnlageTodos AnlageTodoUser[] @relation("AnlageTodoAssignee")
  createdAnlageLogs   AnlageLogEntry[] @relation("AnlageLogAuthor")
  createdDeviceTodos  DeviceTodo[]     @relation("DeviceTodoAuthor")
  createdDeviceLogs   DeviceLogEntry[] @relation("DeviceLogAuthor")
  sentInvitations     Invitation[]     @relation("InvitationAuthor")
  createdWikiPages    WikiPage[]       @relation("WikiPageAuthor")
  updatedWikiPages    WikiPage[]       @relation("WikiPageEditor")
  acknowledgedAlarms  AlarmEvent[]     @relation("AlarmEventAck")
  // Piket
  piketRegionLeaderOf PiketRegion[]    @relation("PiketRegionLeader")
  piketShifts         PiketShift[]     @relation("PiketShiftTech")
  piketAlarmsAsTech   PiketAlarmEvent[] @relation("PiketAlarmTech")
  piketAlarmsAsLeader PiketAlarmEvent[] @relation("PiketAlarmLeader")
  piketAlarmsAckedBy  PiketAlarmEvent[] @relation("PiketAlarmAck")

  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// 2FA-Challenge für privilegierte Rollen (Admin + Verwalter).
/// Nach Login mit korrektem Passwort wird ein 6-stelliger Code per E-Mail
/// gesendet und hier als bcrypt-Hash gespeichert. Ungenutzt/abgelaufen wird
/// er vom Cleanup-Job gelöscht.
model AuthChallenge {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  codeHash    String   @map("code_hash")
  attempts    Int      @default(0)
  consumedAt  DateTime? @map("consumed_at")
  expiresAt   DateTime  @map("expires_at")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_challenges")
}

/// Passwort-Reset-Token. Wird per E-Mail verschickt (Link), ist einmalig und
/// kurzlebig. Nur der bcrypt-Hash wird gespeichert – das Klartext-Token
/// existiert nur in der E-Mail bzw. im Browser des Benutzers.
model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── Activity Log (Audit-Trail) ────────────────────────────────────────────────
//
// Protokolliert alle Benutzer-Aktionen sowie relevante System-Events.
// Wird in api-Routen via withActivityLog-Middleware / logActivity() geschrieben.
model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  /// Wer hat die Aktion ausgelöst (null bei Systemaktionen/Logins fehlgeschlagen)
  userId     String?  @map("user_id") @db.Uuid
  userEmail  String?  @map("user_email")
  /// z.B. "anlage.create", "device.update", "user.login", "vpn.deploy"
  action     String
  /// Was wurde verändert (z.B. "anlage", "device", "user", "peer")
  entityType String?  @map("entity_type")
  /// ID der Entität
  entityId   String?  @map("entity_id")
  /// Zusatz-Details als JSON (z.B. geänderte Felder, Ziel-Daten)
  details    Json?
  /// HTTP-Methode + Pfad
  method     String?
  path       String?
  /// HTTP-Status
  statusCode Int?     @map("status_code")
  /// Client-IP
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  /// System-Rolle: darf NICHT editiert oder gelöscht werden (z.B. Admin).
  /// Nur durch Seed gesetzt. Wenn true → Role hat automatisch alle Permissions.
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model UserGroup {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      UserGroupMember[]
  groupAnlagen GroupAnlage[]
  groupDevices GroupDevice[]
  assignedTodos AnlageTodoGroup[] @relation("AnlageTodoAssignedGroup")

  @@map("user_groups")
}

model UserGroupMember {
  userId     String    @map("user_id") @db.Uuid
  groupId    String    @map("group_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group_members")
}

// ─── Anlagen ──────────────────────────────────────────────────────────────────

model Anlage {
  id              String   @id @default(uuid()) @db.Uuid
  projectNumber   String?  @map("project_number")
  name            String
  description     String?
  street          String?
  zip             String?
  city            String?
  country         String?  @default("Schweiz")
  contactName     String?  @map("contact_name")
  contactPhone    String?  @map("contact_phone")
  contactMobile   String?  @map("contact_mobile")
  contactEmail    String?  @map("contact_email")
  notes           String?
  latitude        Float?
  longitude       Float?
  hasHeatPump     Boolean  @default(false) @map("has_heat_pump")
  hasBoiler       Boolean  @default(false) @map("has_boiler")
  /// Steuert die Offline-Überwachung für diese Anlage: Wenn true, wird bei
  /// länger als threshold Minuten offline geratenen Geräten automatisch eine
  /// Systembenachrichtigung (Mail) ausgelöst – an die zentral in
  /// SystemSettings konfigurierte Adresse. false = keine Überwachung für
  /// diese Anlage.
  offlineMonitoringEnabled Boolean @default(true) @map("offline_monitoring_enabled")
  /// Minimaler Abstand in Minuten zwischen ausgehenden Alarm-Meldungen für
  /// diese Anlage. Solange innerhalb des Fensters bereits eine Meldung
  /// versendet wurde, werden weitere Alarm-Events zwar erkannt + gespeichert,
  /// aber NICHT versendet (Deliveries = SKIPPED, Grund "rate_limited").
  /// Default 60 = max. 1 Meldung pro Stunde.
  alarmRateLimitMinutes    Int     @default(60) @map("alarm_rate_limit_minutes")
  /// Grund-Verzögerung in Minuten, die auf jeden externen (nicht-Template)
  /// Empfänger dieser Anlage addiert wird. Default 10. Für Kunden nicht sichtbar.
  alarmBaseDelayMinutes    Int     @default(10) @map("alarm_base_delay_minutes")
  /// Vertragsstufe. NONE + A: Piketdienst/Ygnis PM standardmässig deaktiviert.
  /// B + C: Piketdienst/Ygnis PM standardmässig aktiv. In den Alarm-
  /// einstellungen kann das pro Anlage manuell übersteuert werden.
  contract        AnlageContract @default(NONE)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  anlageDevices AnlageDevice[]
  directUsers   UserDirectAnlage[]
  groupAnlagen  GroupAnlage[]
  todos         AnlageTodo[]
  logEntries    AnlageLogEntry[]
  vpnAnlage     VpnAnlage?
  erzeuger      AnlageErzeuger[]
  alarmRecipients AlarmRecipient[]
  alarmEvents     AlarmEvent[]

  @@map("anlagen")
}

/// Ordner im Erzeuger-Katalog. Beliebig tief verschachtelbar via
/// parentId. Die Wurzel-Ebene entspricht einer "Kategorie", darunter
/// können weitere Unter-Ordner liegen (z.B. Hersteller, Baureihen).
/// Typen hängen an beliebigen Knoten im Baum.
model ErzeugerCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  parent    ErzeugerCategory?  @relation("ErzeugerCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ErzeugerCategory[] @relation("ErzeugerCategoryTree")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  types ErzeugerType[]

  @@unique([name, parentId])
  @@index([parentId])
  @@map("erzeuger_categories")
}

/// Konkreter Erzeuger-Typ innerhalb einer Kategorie (z.B. "Wärmepumpe XY").
/// Pro Typ wird festgelegt, ob beim Anlegen in einer Anlage eine
/// Seriennummer erforderlich ist (Default: true).
model ErzeugerType {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  /// Kategorie, zu der dieser Typ gehört. Nullable für Bestandsdaten – neue
  /// Typen werden über das UI immer mit Kategorie angelegt.
  categoryId     String?  @map("category_id") @db.Uuid
  category       ErzeugerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /// Ob beim Hinzufügen zu einer Anlage die Seriennummer obligatorisch ist.
  serialRequired Boolean  @default(true) @map("serial_required")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  anlagen AnlageErzeuger[]

  @@index([categoryId])
  @@map("erzeuger_types")
}

/// Erzeuger-Zuweisung pro Anlage: verweist auf einen ErzeugerType und
/// trägt optional eine Seriennummer des konkreten Geräts. Ob die
/// Seriennummer verpflichtend ist, steuert der SystemSetting-Key
/// `erzeuger.serialRequired`.
model AnlageErzeuger {
  id           String   @id @default(uuid()) @db.Uuid
  anlageId     String   @map("anlage_id") @db.Uuid
  anlage       Anlage   @relation(fields: [anlageId], references: [id], onDelete: Cascade)
  typeId       String   @map("type_id") @db.Uuid
  type         ErzeugerType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  serialNumber String?  @map("serial_number")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([anlageId])
  @@index([typeId])
  @@map("anlage_erzeuger")
}

model AnlageDevice {
  anlageId   String   @map("anlage_id") @db.Uuid
  deviceId   String   @map("device_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  anlage     Anlage   @relation(fields: [anlageId], references: [id], onDelete: Cascade)
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([anlageId, deviceId])
  @@index([deviceId])
  @@map("anlage_devices")
}

// ─── Devices ──────────────────────────────────────────────────────────────────

model Device {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  serialNumber    String       @unique @map("serial_number")
  // Wenn ein zweiter Pi sich mit derselben YControl-SN registriert, wird er als
  // Konflikt-Record angelegt. requestedSerialNumber speichert die ursprüngliche SN,
  // serialNumber bekommt einen "CONFLICT-<piSerial>" Marker.
  hasConflict           Boolean @default(false) @map("has_conflict")
  requestedSerialNumber String? @map("requested_serial_number")
  status          DeviceStatus @default(UNKNOWN)
  /// Wenn true, hat der Benutzer auf der Visu alle Alarme dieses Geräts
  /// unterdrückt (Kundentermin etc.). Der Pi sendet dann KEINE Alarme an
  /// die Cloud; die Cloud setzt das Flag nur, damit die Oberfläche den
  /// Zustand sichtbar macht.
  alarmsSuppressed Boolean     @default(false) @map("alarms_suppressed")
  alarmsSuppressedAt DateTime? @map("alarms_suppressed_at")
  isApproved      Boolean      @default(false) @map("is_approved")
  lastSeen        DateTime?    @map("last_seen")
  piSerial        String?      @map("pi_serial")
  deviceSecret    String?      @map("device_secret")
  firmwareVersion String?      @map("firmware_version")
  agentVersion    String?      @map("agent_version")
  ipAddress       String?      @map("ip_address")
  projectNumber   String?      @map("project_number")
  schemaNumber    String?      @map("schema_number")
  visuVersion     String?      @map("visu_version")
  vpnActive       Boolean      @default(false) @map("vpn_active")
  httpActive      Boolean      @default(false) @map("http_active")
  hasRouter       Boolean      @default(false) @map("has_router")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // LAN-Gerät: über ein übergeordnetes Pi-Gerät via VPN erreichbar
  parentDeviceId  String?      @map("parent_device_id") @db.Uuid
  lanTargetIp     String?      @map("lan_target_ip")
  lanTargetPort   Int?         @map("lan_target_port")

  parentDevice  Device?  @relation("DeviceChildren", fields: [parentDeviceId], references: [id], onDelete: SetNull)
  childDevices  Device[] @relation("DeviceChildren")

  anlageDevices AnlageDevice[]
  directUsers   UserDirectDevice[]
  directGroups  GroupDevice[]
  todos         DeviceTodo[]
  logEntries    DeviceLogEntry[]
  vpnDevice     VpnDevice?
  alarmEvents   AlarmEvent[]
  backups       DeviceBackup[]

  @@index([piSerial])
  @@map("devices")
}

// ─── Access Control Join Tables ───────────────────────────────────────────────

model UserDirectAnlage {
  userId     String   @map("user_id") @db.Uuid
  anlageId   String   @map("anlage_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anlage     Anlage   @relation(fields: [anlageId], references: [id], onDelete: Cascade)

  @@id([userId, anlageId])
  @@index([anlageId])
  @@map("user_direct_anlagen")
}

model UserDirectDevice {
  userId     String   @map("user_id") @db.Uuid
  deviceId   String   @map("device_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([userId, deviceId])
  @@index([deviceId])
  @@map("user_direct_devices")
}

model GroupAnlage {
  groupId    String    @map("group_id") @db.Uuid
  anlageId   String    @map("anlage_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  anlage     Anlage    @relation(fields: [anlageId], references: [id], onDelete: Cascade)

  @@id([groupId, anlageId])
  @@index([anlageId])
  @@map("group_anlagen")
}

model GroupDevice {
  groupId    String    @map("group_id") @db.Uuid
  deviceId   String    @map("device_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at")
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceId])
  @@index([deviceId])
  @@map("group_devices")
}

// ─── Todos & Logs ─────────────────────────────────────────────────────────────

model AnlageTodo {
  id              String     @id @default(uuid()) @db.Uuid
  anlageId        String     @map("anlage_id") @db.Uuid
  title           String
  details         String?
  status          TodoStatus @default(OPEN)
  /// Optionaler Fälligkeits-Termin – wird im Todo-Überblick zur Sortierung
  /// und für Überfällig-Kennzeichnung genutzt.
  dueDate         DateTime?  @map("due_date")
  /// URLs angehängter Fotos (werden client-seitig komprimiert und in
  /// /uploads/photos/ gespeichert). Leeres Array = kein Foto.
  photoUrls       String[]   @default([]) @map("photo_urls")
  createdById     String     @map("created_by_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  anlage          Anlage     @relation(fields: [anlageId], references: [id], onDelete: Cascade)
  createdBy       User       @relation("AnlageTodoAuthor", fields: [createdById], references: [id])
  assignedUsers   AnlageTodoUser[]
  assignedGroups  AnlageTodoGroup[]

  @@index([anlageId])
  @@index([status, dueDate])
  @@map("anlage_todos")
}

/// Zuweisung eines Todos an konkrete Benutzer (mehrere möglich).
model AnlageTodoUser {
  todoId String     @map("todo_id") @db.Uuid
  userId String     @map("user_id") @db.Uuid
  todo   AnlageTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user   User       @relation("AnlageTodoAssignee", fields: [userId], references: [id], onDelete: Cascade)

  @@id([todoId, userId])
  @@index([userId])
  @@map("anlage_todo_users")
}

/// Zuweisung eines Todos an Benutzer-Gruppen (mehrere möglich).
model AnlageTodoGroup {
  todoId  String     @map("todo_id") @db.Uuid
  groupId String     @map("group_id") @db.Uuid
  todo    AnlageTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  group   UserGroup  @relation("AnlageTodoAssignedGroup", fields: [groupId], references: [id], onDelete: Cascade)

  @@id([todoId, groupId])
  @@index([groupId])
  @@map("anlage_todo_groups")
}

model AnlageLogEntry {
  id          String   @id @default(uuid()) @db.Uuid
  anlageId    String   @map("anlage_id") @db.Uuid
  message     String
  /// URLs angehängter Fotos (siehe AnlageTodo.photoUrls).
  photoUrls   String[] @default([]) @map("photo_urls")
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  anlage      Anlage   @relation(fields: [anlageId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("AnlageLogAuthor", fields: [createdById], references: [id])

  @@index([anlageId])
  @@map("anlage_log_entries")
}

model DeviceTodo {
  id          String     @id @default(uuid()) @db.Uuid
  deviceId    String     @map("device_id") @db.Uuid
  title       String
  details     String?
  status      TodoStatus @default(OPEN)
  createdById String     @map("created_by_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  device      Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("DeviceTodoAuthor", fields: [createdById], references: [id])

  @@index([deviceId])
  @@map("device_todos")
}

model DeviceLogEntry {
  id          String   @id @default(uuid()) @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid
  message     String
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("DeviceLogAuthor", fields: [createdById], references: [id])

  @@index([deviceId])
  @@map("device_log_entries")
}

// ─── Invitations ─────────────────────────────────────────────────────────

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  email       String
  token       String    @unique
  roleId      String?   @map("role_id") @db.Uuid
  groupIds    String[]  @map("group_ids") @db.Uuid
  anlageIds   String[]  @map("anlage_ids") @db.Uuid
  deviceIds   String[]  @map("device_ids") @db.Uuid
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  invitedById String    @map("invited_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  invitedBy   User      @relation("InvitationAuthor", fields: [invitedById], references: [id])

  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ─── Device Backups ───────────────────────────────────────────────────────────
//
// Manuell ausgelöste Backups der Pi-Daten (`/home/pi/ycontrol-data/external` +
// `/assets`). Der Cloud-Backend triggert via MQTT, der Pi-Agent streamt einen
// tar.gz-Stream per HTTP zurück. Die Cloud verteilt parallel an alle aktiven
// Backup-Targets (Syno WebDAV / Infomaniak S3) und schreibt hier den Status.
// Pro Gerät bleiben max. 5 Backups erhalten – ältere werden auf den Targets
// und in der DB gelöscht.

enum DeviceBackupStatus {
  /// Cloud hat Job angelegt, Agent benachrichtigt, wartet auf Upload.
  PENDING
  /// Agent streamt gerade die tar.gz-Datei in die Cloud.
  UPLOADING
  /// Cloud verteilt an die Backup-Targets.
  DISTRIBUTING
  /// Mindestens ein Target hat das Backup gespeichert.
  OK
  /// Vor Ablauf der Frist abgebrochen oder Fehler.
  FAILED
}

enum DeviceBackupTargetStatus {
  /// Target war zum Zeitpunkt des Backups deaktiviert.
  SKIPPED
  /// Upload an dieses Target läuft.
  PENDING
  /// Auf dem Target gespeichert.
  OK
  /// Auf diesem Target fehlgeschlagen.
  FAILED
}

enum DeviceRestoreStatus {
  PENDING
  RUNNING
  OK
  FAILED
}

model DeviceBackup {
  id             String              @id @default(uuid()) @db.Uuid
  deviceId       String              @map("device_id") @db.Uuid
  device         Device              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  /// Einmal-Token, mit dem der Agent den Upload autorisiert. Wird nach
  /// erfolgreichem Upload geleert.
  uploadToken    String?             @map("upload_token")
  /// Schlüssel auf dem Target (Format `<deviceSerial>/<ISO>.tar.gz`).
  objectKey      String              @map("object_key")
  sizeBytes      BigInt?             @map("size_bytes")
  status         DeviceBackupStatus  @default(PENDING)
  errorMessage   String?             @map("error_message")
  infomaniakStatus   DeviceBackupTargetStatus @default(SKIPPED) @map("infomaniak_status")
  infomaniakError    String?                  @map("infomaniak_error")
  /// Letzter Restore-Versuch dieses Backups (für UI-Status).
  lastRestoreStatus  DeviceRestoreStatus?  @map("last_restore_status")
  lastRestoreError   String?               @map("last_restore_error")
  lastRestoreAt      DateTime?             @map("last_restore_at")
  /// Optional: Welcher Benutzer hat das Backup ausgelöst.
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  @@index([deviceId, createdAt])
  @@index([status])
  @@map("device_backups")
}

// ─── System Settings ──────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ─── VPN ──────────────────────────────────────────────────────────────────────

/// VPN-Subnetz für eine Anlage (Zone B: 10.11.x.0/24 … 10.255.x.0/24)
/// subnetIndex 1 → 10.11.1.0/24, 500 → 10.12.244.0/24, max 62 720 Anlagen
model VpnAnlage {
  id           String   @id @default(uuid()) @db.Uuid
  anlageId     String   @unique @map("anlage_id") @db.Uuid
  anlage       Anlage   @relation(fields: [anlageId], references: [id], onDelete: Cascade)

  /// Fortlaufender Index – bestimmt das /24-Subnetz eindeutig
  subnetIndex  Int      @unique @map("subnet_index")

  /// Reales LAN-Präfix des Pi (Standardwert "192.168.10", ohne führenden Punkt)
  localPrefix  String   @default("192.168.10") @map("local_prefix")

  /// WireGuard-Schlüsselpaar des Pi (vom Cloud generiert, im Download enthalten)
  piPublicKey  String?  @map("pi_public_key")
  piPrivateKey String?  @map("pi_private_key")

  createdAt    DateTime @default(now()) @map("created_at")

  @@map("vpn_anlagen")
}

/// WireGuard-VPN-Konfiguration pro Gerät
model VpnDevice {
  id           String   @id @default(uuid()) @db.Uuid
  deviceId     String   @unique @map("device_id") @db.Uuid
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  /// WireGuard-IP des Pi im VPN-Netz, z.B. "10.11.0.2" – muss eindeutig sein
  vpnIp        String   @unique @map("vpn_ip")

  /// Reales LAN-Präfix des Pi (erste drei Oktette), z.B. "192.168.10"
  localPrefix  String   @default("192.168.10") @map("local_prefix")

  /// HTTP-Port der Visu auf dem Zielgerät (Default: 80)
  visuPort     Int      @default(80) @map("visu_port")

  /// LAN-IP des Pi (bei Router-Software), z.B. "192.168.10.31"
  /// Wird zur VPN-LAN-Adresse umgerechnet (10.A.B.x via NETMAP) für Visu-Proxy
  /// Leer = Pi ohne Router (Visu direkt über VPN-IP erreichbar)
  visuIp       String?  @map("visu_ip")

  /// WAN-IP des Pi (bei Router-Software), z.B. "192.168.1.100"
  /// Informativer Wert – das Netzwerk in dem der Pi per WAN angeschlossen ist
  wanIp        String?  @map("wan_ip")

  /// WireGuard-Schlüsselpaar des Pi (vom Cloud generiert)
  piPublicKey  String?  @map("pi_public_key")
  piPrivateKey String?  @map("pi_private_key")

  createdAt    DateTime @default(now()) @map("created_at")

  @@map("vpn_devices")
}

/// WireGuard-Client-Peer (Techniker, Admin, mobiler Zugriff)
/// Peer-IP: Zone A (10.0.x.y, peerIndex bestimmt x.y)
model VpnPeer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  publicKey   String   @unique @map("public_key")

  /// Privater Schlüssel (Server-seitig generiert) – für Config-Download
  privateKey  String?  @map("private_key")

  /// Fortlaufender Index – bestimmt die Zone-A-IP
  peerIndex   Int      @unique @map("peer_index")

  /// Optional: verknüpfter Cloud-Benutzer
  userId      String?  @map("user_id") @db.Uuid
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vpn_peers")
}

// ─── Wiki ─────────────────────────────────────────────────────────────────────
//
// Einfaches hierarchisches Wiki. Seiten haben einen Titel, Icon (Emoji),
// eine Baumstruktur via parentId und einen TipTap/ProseMirror JSON-Inhalt.
model WikiPage {
  id          String   @id @default(uuid()) @db.Uuid
  /// URL-freundlicher Slug (einzigartig, für Deep-Links und Erwähnungen)
  slug        String   @unique
  title       String
  /// Optionales Emoji, das im Seitenbaum vor dem Titel angezeigt wird
  icon        String?
  /// Unterscheidet Container-Knoten (Ordner, kein Inhalt) von echten Seiten.
  type        WikiNodeType @default(PAGE)
  /// TipTap-Dokument (ProseMirror-JSON) als Json gespeichert
  content     Json     @default("{}")
  /// Extrahierter Reintext aus `content` für Volltextsuche. Wird bei jedem
  /// Write aus dem TipTap-Dokument generiert.
  searchText  String   @default("") @map("search_text")
  /// Ursprungs-Sprache (ISO 639-1). Wird beim automatischen Übersetzen als
  /// "source" verwendet. Default "de".
  sourceLang  String   @default("de") @map("source_lang")
  /// Eltern-Seite für die Baumstruktur (NULL = Root-Level)
  parentId    String?  @map("parent_id") @db.Uuid
  parent      WikiPage?  @relation("WikiTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    WikiPage[] @relation("WikiTree")
  /// Reihenfolge innerhalb der Geschwister-Ebene
  sortOrder   Int      @default(0) @map("sort_order")

  permissions WikiPagePermission[]
  translations WikiPageTranslation[]

  createdById String   @map("created_by_id") @db.Uuid
  createdBy   User     @relation("WikiPageAuthor", fields: [createdById], references: [id])
  updatedById String   @map("updated_by_id") @db.Uuid
  updatedBy   User     @relation("WikiPageEditor", fields: [updatedById], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([slug])
  @@map("wiki_pages")
}

/// Zugriffsrechte pro Wiki-Knoten. Einträge auf einem Ordner wirken auf alle
/// darunterliegenden Seiten/Ordner, es sei denn der Nachkomme hat selbst
/// Einträge – dann gilt ausschließlich die nächstgelegene Regel (am Knoten
/// oder seinem nächsten Vorfahren mit Einträgen). Hat ein Zweig gar keine
/// Einträge, greifen die globalen wiki:*-Permissions.
model WikiPagePermission {
  id         String           @id @default(uuid()) @db.Uuid
  pageId     String           @map("page_id") @db.Uuid
  page       WikiPage         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  targetType WikiAccessTarget @map("target_type")
  /// ID des Ziels (Role.id, UserGroup.id oder User.id je nach targetType)
  targetId   String           @map("target_id") @db.Uuid
  level      WikiAccessLevel
  createdAt  DateTime         @default(now()) @map("created_at")

  @@unique([pageId, targetType, targetId])
  @@index([targetId])
  @@map("wiki_page_permissions")
}

/// Automatisch oder manuell gepflegte Übersetzung einer Wiki-Seite.
/// Beim Save der Quellseite werden Übersetzungen regeneriert, es sei denn
/// `isEdited = true` (Benutzer hat die Übersetzung korrigiert – dann bleibt
/// sie unverändert).
model WikiPageTranslation {
  id          String   @id @default(uuid()) @db.Uuid
  pageId      String   @map("page_id") @db.Uuid
  page        WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  /// ISO 639-1 Sprachcode, lower-case (z.B. "en", "it", "fr")
  lang        String
  title       String
  content     Json     @default("{}")
  searchText  String   @default("") @map("search_text")
  /// true, wenn ein User die Übersetzung manuell editiert hat. In diesem
  /// Fall wird sie beim erneuten Save der Quellseite NICHT überschrieben.
  isEdited    Boolean  @default(false) @map("is_edited")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") @db.Uuid

  @@unique([pageId, lang])
  @@index([pageId])
  @@map("wiki_page_translations")
}

// ─── Alarme ───────────────────────────────────────────────────────────────────

/// Global definierte "Interne Alarm-Empfänger". Der Kunde (Rolle "benutzer")
/// sieht sie nie – nur Admins/Verwalter können sie pro Anlage aktivieren.
/// Zwei System-Einträge werden geseeded (Piketdienst, Ygnis PM) und können
/// nicht gelöscht werden; weitere Einträge kann der Admin selber anlegen.
/// Die E-Mail-Adresse wird hier zentral gepflegt und zur Versand-Zeit
/// vom Dispatcher nachgeschlagen.
model InternalAlarmRecipientTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  /// Stabiler Key (z.B. "piketdienst", "ygnis_pm"). Für System-Einträge
  /// einmalig geseedet, für Custom-Einträge generiert.
  key       String   @unique
  /// Anzeigename für Admins, z.B. "Piketdienst".
  label     String
  /// Zentral gepflegte E-Mail-Adresse. Leer = Dispatcher überspringt.
  email     String?
  /// Global gepflegter Wochenzeitplan. null/leer = "always".
  schedule     Json?
  /// Welche Prioritäten an dieses Template gehen. Leeres Array = alle.
  priorities   AlarmPriority[] @default([])
  /// Verzögerung in Minuten zwischen Alarm und Versand.
  delayMinutes Int             @default(0) @map("delay_minutes")
  /// Wenn true: an einem Feiertag (Holiday-Tabelle) werden Meldungen
  /// unabhängig vom Wochenzeitplan versendet.
  sendOnHoliday Boolean        @default(false) @map("send_on_holiday")
  /// Nur für den Piketdienst-Template relevant: EMAIL = klassisch per Mail,
  /// PIKET_MANAGER = über den Bereichs-/Schicht-Workflow mit Eskalation.
  deliveryChannel PiketDeliveryChannel @default(EMAIL) @map("delivery_channel")
  /// true für Piketdienst + Ygnis PM – können nicht gelöscht werden.
  isSystem  Boolean  @default(false) @map("is_system")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt  @map("updated_at")

  recipients AlarmRecipient[]

  @@map("internal_alarm_recipient_templates")
}

/// Alarm-Empfänger pro Anlage. Ein Empfänger beschreibt WOHIN bei einem
/// Alarm benachrichtigt wird (E-Mail, SMS, Telegram) und optional WELCHE
/// Prioritäten an ihn gehen.
model AlarmRecipient {
  id           String             @id @default(uuid()) @db.Uuid
  anlageId     String             @map("anlage_id") @db.Uuid
  anlage       Anlage             @relation(fields: [anlageId], references: [id], onDelete: Cascade)
  type         AlarmRecipientType
  /// E-Mail-Adresse, Telefonnummer (E.164) oder Telegram-Chat-ID.
  /// Bei internen Empfängern (templateId gesetzt) leer – die Adresse kommt
  /// dynamisch aus dem Template, damit zentrale Änderungen überall greifen.
  target       String
  /// Nur bei type = EMAIL_AND_SMS verwendet: Telefonnummer (E.164).
  smsTarget    String?            @map("sms_target")
  /// Optionaler Anzeigename (z.B. "Bereitschaft Müller").
  label        String?
  /// Liste der Prioritäten, die an diesen Empfänger gehen. Leere Liste =
  /// alle Prioritäten.
  priorities   AlarmPriority[]    @default([])
  /// Verzögerung in Minuten, bevor der Versand ausgelöst wird (Eskalation).
  /// 0 = sofort.
  delayMinutes Int                @default(0) @map("delay_minutes")
  /// Wochenzeitplan. JSON-Struktur (ab v2):
  ///   {
  ///     "mode": "always" | "weekly",
  ///     "days": [                 // index 0 = Montag ... 6 = Sonntag
  ///       {
  ///         "enabled": true,
  ///         "windows": [           // 0..n Zeitfenster pro Tag
  ///           { "start": "HH:MM", "end": "HH:MM" }
  ///         ]
  ///       },
  ///       ... (7 Einträge)
  ///     ]
  ///   }
  /// mode="always" → Empfänger bekommt Alarme jederzeit.
  /// mode="weekly" → nur wenn der aktuelle Wochentag `enabled` ist und die
  ///                  Uhrzeit in einem der Fenster liegt (Fenster darf
  ///                  mitternacht umschlagen, z.B. 22:00–06:00).
  /// Legacy v1-Struktur ({ enabled, start, end }) wird weiterhin toleriert.
  /// Ausserhalb des Zeitplans wird der Alarm NICHT nachgeholt, sondern
  /// definitiv verworfen (Delivery=SKIPPED, Grund "out_of_schedule").
  /// null = wie "always".
  schedule     Json?
  /// true = interner Empfänger (für Admins/Verwalter). Kunden (benutzer-Rolle)
  /// bekommen ihn in der API nicht ausgeliefert und sehen ihn nicht im UI.
  isInternal   Boolean            @default(false) @map("is_internal")
  /// Optional: FK auf ein globales Template. Wenn gesetzt, wird `target` beim
  /// Versand aus dem Template aufgelöst (zentrale Pflege der Adresse).
  templateId   String?            @map("template_id") @db.Uuid
  template     InternalAlarmRecipientTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt  @map("updated_at")

  deliveries AlarmEventDelivery[]

  @@index([anlageId])
  @@index([templateId])
  @@map("alarm_recipients")
}

/// Ein konkreter Alarm, der vom Agent gemeldet wurde.
/// Die Alarm-Regeln selbst bleiben auf dem Pi – hier wird nur der
/// ausgelöste Zustand gespeichert (inkl. Historie / Quittierungen).
model AlarmEvent {
  id               String           @id @default(uuid()) @db.Uuid
  deviceId         String           @map("device_id") @db.Uuid
  device           Device           @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  /// Anlage zum Zeitpunkt des Alarms (kann null sein, wenn Device gerade
  /// keiner Anlage zugewiesen ist – dann wird nicht versendet).
  anlageId         String?          @map("anlage_id") @db.Uuid
  anlage           Anlage?          @relation(fields: [anlageId], references: [id], onDelete: SetNull)

  /// Eindeutige Kennung dieser Alarm-Definition beim Pi.
  /// Wird aus der Visu-Tabelle alarm_definitions übernommen und zusammen
  /// mit der deviceId zur Deduplizierung wiederkehrender Alarme genutzt.
  alarmKey         String           @map("alarm_key")
  priority         AlarmPriority
  message          String
  /// Optionaler MQTT-Topic, auf dem der Pi den Trigger gelesen hat
  /// (z.B. "modbusgateway/data/wp_status"). Reine Info.
  source           String?
  /// Roh-Payload vom Agent für Forensik / Debugging.
  rawPayload       Json?            @map("raw_payload")
  status           AlarmEventStatus @default(ACTIVE)
  activatedAt      DateTime         @default(now()) @map("activated_at")
  clearedAt        DateTime?        @map("cleared_at")
  acknowledgedAt   DateTime?        @map("acknowledged_at")
  acknowledgedById String?          @map("acknowledged_by_id") @db.Uuid
  acknowledgedBy   User?            @relation("AlarmEventAck", fields: [acknowledgedById], references: [id])

  deliveries AlarmEventDelivery[]
  piketAlarm PiketAlarmEvent?

  @@index([deviceId, activatedAt])
  @@index([anlageId, activatedAt])
  @@index([status])
  @@index([deviceId, alarmKey, status])
  @@map("alarm_events")
}

/// Versand-Log pro Empfänger: welcher Kanal, an wen, mit welchem Ergebnis.
/// Bleibt erhalten, auch wenn der Empfänger später gelöscht wird
/// (target/type sind kopiert).
model AlarmEventDelivery {
  id           String              @id @default(uuid()) @db.Uuid
  eventId      String              @map("event_id") @db.Uuid
  event        AlarmEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipientId  String?             @map("recipient_id") @db.Uuid
  recipient    AlarmRecipient?     @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  type         AlarmRecipientType
  target       String
  status       AlarmDeliveryStatus @default(PENDING)
  errorMessage String?             @map("error_message")
  /// Zeitpunkt, zu dem der Versand frühestens ausgeführt werden soll.
  /// Bei `delayMinutes = 0` ist das now() und wird sofort bearbeitet.
  /// Bei Eskalations-Verzögerung zeigt scheduledAt in die Zukunft; der
  /// Delivery-Worker pollt ≤scheduledAt fällige PENDING-Einträge.
  scheduledAt  DateTime?           @map("scheduled_at")
  attemptedAt  DateTime?           @map("attempted_at")
  sentAt       DateTime?           @map("sent_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([eventId])
  @@index([status])
  @@index([status, scheduledAt])
  @@map("alarm_event_deliveries")
}


/// Regel-basierte Feiertage (jahresunabhängig). Admin kann pro Regel
/// aktiv/inaktiv setzen; Standard = alle Luzerner Feiertage. Der Dispatcher
/// berechnet pro Jahr die konkreten Daten.
enum HolidayRuleType {
  FIXED
  EASTER_OFFSET
}

model HolidayRule {
  id           String          @id @default(uuid()) @db.Uuid
  key          String          @unique
  label        String
  type         HolidayRuleType
  fixedMonth   Int?            @map("fixed_month")
  fixedDay     Int?            @map("fixed_day")
  easterOffset Int?            @map("easter_offset")
  region       String?
  isActive     Boolean         @default(true) @map("is_active")
  sortOrder    Int             @default(0) @map("sort_order")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt      @map("updated_at")

  @@map("holiday_rules")
}

/// Firmen-spezifische Sondertage (Betriebsferien, einzelne Brückentage).
/// Gelten nur für das eine konkrete Datum.
model HolidayDate {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("holiday_dates")
}

// ── Piket-Manager ────────────────────────────────────────────────────────────
// Erweitert den Piketdienst-Empfänger: statt Mail direkt an eine Adresse wird
// anhand der PLZ/Land der Anlage ein Bereich (Region) + Tages-Techniker
// (Schicht) ermittelt. Alarm wird per SMS an den Techniker gesendet, nach
// einer Verzögerung angerufen, bei weiterem Ausbleiben an den Bereichsleiter
// eskaliert. Bestätigung erfolgt durch Login + Ack-Klick auf der Cloud.

enum PiketDeliveryChannel {
  EMAIL
  PIKET_MANAGER
}

enum PiketAlarmState {
  PENDING_SMS
  SMS_SENT
  CALL_DUE
  CALL_SENT
  LEADER_DUE
  LEADER_SENT
  ACKNOWLEDGED
  NO_TECH_FOUND
}

/// Bereich innerhalb des Piketdienstes. Kein Geo-Overlap mit anderen Bereichen
/// vorausgesetzt (erste passende Region gewinnt).
model PiketRegion {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  /// Bereichsleiter: wird bei nicht-quittiertem Alarm zum Schluss alarmiert.
  leaderId        String?  @map("leader_id") @db.Uuid
  leader          User?    @relation("PiketRegionLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  /// Backup-Kontakt (E-Mail) falls Leader fehlt.
  leaderFallbackEmail String? @map("leader_fallback_email")
  /// Default-Werte überschreiben die globalen Template-Werte, wenn gesetzt.
  smsToCallMinutes    Int?   @map("sms_to_call_minutes")
  callToLeaderMinutes Int?   @map("call_to_leader_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  zipRanges       PiketRegionZipRange[]
  foreignPrefixes PiketRegionForeignPrefix[]
  shifts          PiketShift[]
  piketAlarms     PiketAlarmEvent[]

  @@map("piket_regions")
}

/// PLZ-Bereich (z.B. 6000–6999). Inklusive von und bis.
model PiketRegionZipRange {
  id       String      @id @default(uuid()) @db.Uuid
  regionId String      @map("region_id") @db.Uuid
  region   PiketRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  fromZip  Int         @map("from_zip")
  toZip    Int         @map("to_zip")

  @@index([regionId])
  @@map("piket_region_zip_ranges")
}

/// Ausland-Präfix; matcht, wenn die Anlagen-PLZ mit diesem Präfix beginnt
/// (z.B. "DE-", "AT-", "FR-").
model PiketRegionForeignPrefix {
  id       String      @id @default(uuid()) @db.Uuid
  regionId String      @map("region_id") @db.Uuid
  region   PiketRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  prefix   String

  @@index([regionId])
  @@map("piket_region_foreign_prefixes")
}

/// Tages-Schicht: welcher Techniker ist heute für diesen Bereich zuständig.
model PiketShift {
  id       String      @id @default(uuid()) @db.Uuid
  regionId String      @map("region_id") @db.Uuid
  region   PiketRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id") @db.Uuid
  user     User        @relation("PiketShiftTech", fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime    @db.Date
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt      @map("updated_at")

  @@unique([regionId, date])
  @@index([date])
  @@map("piket_shifts")
}

/// Zustand eines einzelnen Piket-Alarms. Ein PiketAlarmEvent wird vom
/// Dispatcher erzeugt, sobald ein Alarm auf den Piket-Template-Empfänger
/// trifft UND dessen deliveryChannel = PIKET_MANAGER ist.
model PiketAlarmEvent {
  id            String           @id @default(uuid()) @db.Uuid
  alarmEventId  String           @unique @map("alarm_event_id") @db.Uuid
  alarmEvent    AlarmEvent       @relation(fields: [alarmEventId], references: [id], onDelete: Cascade)
  regionId      String?          @map("region_id") @db.Uuid
  region        PiketRegion?     @relation(fields: [regionId], references: [id], onDelete: SetNull)
  techUserId    String?          @map("tech_user_id") @db.Uuid
  techUser      User?            @relation("PiketAlarmTech", fields: [techUserId], references: [id], onDelete: SetNull)
  leaderUserId  String?          @map("leader_user_id") @db.Uuid
  leaderUser    User?            @relation("PiketAlarmLeader", fields: [leaderUserId], references: [id], onDelete: SetNull)
  state         PiketAlarmState  @default(PENDING_SMS)
  /// Nächster Aktions-Zeitpunkt (z.B. SMS jetzt senden, Anruf fällig, Leader fällig).
  nextActionAt  DateTime?        @map("next_action_at")
  smsAt         DateTime?        @map("sms_at")
  callAt        DateTime?        @map("call_at")
  leaderAt      DateTime?        @map("leader_at")
  acknowledgedAt DateTime?       @map("acknowledged_at")
  acknowledgedById String?       @map("acknowledged_by_id") @db.Uuid
  acknowledgedBy User?           @relation("PiketAlarmAck", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  /// Log der Attempts (JSON mit Einträgen { at, kind, target, status, error? })
  attempts      Json?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt      @map("updated_at")

  @@index([state, nextActionAt])
  @@map("piket_alarm_events")
}
