{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Docker (PostgreSQL + Mosquitto)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "cwd": ".",
      "autoPort": true
    },
    {
      "name": "Backend (Node.js API)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "./backend",
      "port": 3000
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "./frontend",
      "port": 5173
    }
  ]
}
